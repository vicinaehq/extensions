{
  "$schema": "https://raw.githubusercontent.com/vicinaehq/vicinae/refs/heads/main/extra/schemas/extension.json",
  "name": "timer",
  "title": "Timer",
  "description": "Create and manage system-native background timers using natural language.",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "platforms": ["Linux"],
  "author": "HarshNarayanJha",
  "contributors": [],
  "pastContributors": [],
  "icon": "extension_icon.png",
  "commands": [
    {
      "name": "index",
      "title": "Start Timer",
      "description": "Start a new timer or select from presets.",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "presets",
      "type": "textfield",
      "required": false,
      "title": "Timer Presets",
      "description": "Comma-separated presets (e.g., 5m Tea, 25m Pomodoro)",
      "default": "5m Tea, 25m Pomodoro"
    }
  ],
  "scripts": {
    "build": "vici build",
    "dev": "vici develop",
    "format": "biome format --write src",
    "lint": "vici lint",
    "publish": "./publish.sh"
  },
  "dependencies": {
    "@vicinae/api": "^0.22.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "@types/bun": "^1.3.14",
    "typescript": "^5.9.2"
  },
  "trustedDependencies": [
    "yarn"
  ]
}
