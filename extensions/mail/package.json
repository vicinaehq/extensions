{
  "$schema": "https://raw.githubusercontent.com/vicinaehq/vicinae/refs/heads/main/extra/schemas/extension.json",
  "name": "mail",
  "title": "Mail",
  "description": "Read emails with Vicinae",
  "categories": [],
  "license": "MIT",
  "author": "Damnjelly",
  "contributors": [],
  "pastContributors": [],
  "icon": "extension_icon.png",
  "commands": [
    {
      "name": "mailbox",
      "title": "Inbox",
      "subtitle": "list inbox",
      "description": "Show the inbox of the default user",
      "mode": "view",
      "keywords": [
        "mail",
        "inbox"
      ]
    },
    {
      "name": "manage-accounts",
      "title": "Manage Accounts",
      "subtitle": "Manage email accounts",
      "description": "View, add, edit, and delete email accounts",
      "mode": "view"
    }
  ],
  "scripts": {
    "build": "vici build",
    "dev": "vici develop",
    "format": "biome format --write src",
    "lint": "vici lint"
  },
  "dependencies": {
    "@vicinae/api": "^0.20.15",
    "imapflow": "^1.3.3",
    "postal-mime": "^2.2.0",
    "turndown": "^7.2.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.2",
    "typescript": "^5.9.2"
  }
}
