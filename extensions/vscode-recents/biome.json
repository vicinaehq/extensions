{
    "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
    "formatter": {
        "enabled": true,
        "includes": ["src/**/*.ts", "src/**/*.tsx", "*.json"],
        "lineWidth": 135,
        "indentWidth": 4,
        "indentStyle": "space"
    },
    "linter": {
        "enabled": true,
        "includes": ["src/**/*.ts", "src/**/*.tsx", "*.json"],
        "rules": {
            "recommended": true
        }
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "double",
            "semicolons": "always"
        }
    }
}
