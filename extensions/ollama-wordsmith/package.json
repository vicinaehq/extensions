    },
    {
      "name": "maxHistorySize",
      "type": "textfield",
      "title": "Max History Size",
      "description": "Maximum number of history entries to keep",
      "default": "50",
      "placeholder": "50",
      "required": false
    }
  ],
  "scripts": {
    "build": "vici build",
    "dev": "vici develop",
    "lint": "vici lint"
  },
  "dependencies": {
    "@vicinae/api": "^0.16.11"
  },
  "devDependencies": {
    "typescript": "^5.9.2"
  }
}
