{
  "$schema": "https://raw.githubusercontent.com/vicinaehq/vicinae/refs/heads/main/extra/schemas/extension.json",
  "name": "npm",
  "title": "NPM",
  "description": "An extenstion to manage npm packages",
  "categories": ["Developer Tools"],
  "license": "MIT",
  "author": "FredrikMWold",
  "contributors": [],
  "pastContributors": [],
  "icon": "NPM.png",
  "commands": [
    {
      "name": "npm-install",
      "title": "Install project packages",
      "subtitle": "Install project packages",
      "description": "Install project packages",
      "mode": "view"
    },
    {
      "name": "npm-install-global",
      "title": "Install global packages",
      "subtitle": "Install global packages",
      "description": "Install global packages",
      "mode": "view"
    },
    {
      "name": "npm-uninstall",
      "title": "Uninstall project packages",
      "subtitle": "Uninstall project packages",
      "description": "Uninstall project packages",
      "mode": "view"
    },
    {
      "name": "npm-uninstall-global",
      "title": "Uninstall global packages",
      "subtitle": "Uninstall global packages",
      "description": "Uninstall global packages",
      "mode": "view"
    },
    {
      "name": "npm-update-global",
      "title": "Update global packages",
      "subtitle": "Update global packages",
      "description": "Update global packages",
      "mode": "view"
    },
    {
      "name": "npm-update",
      "title": "Update project packages",
      "subtitle": "Update project packages",
      "description": "Update project packages",
      "mode": "view"
    },
    {
      "name": "npm-search",
      "title": "Search packages",
      "subtitle": "Search packages",
      "description": "Search packages",
      "mode": "view"
    }
  ],
  "preferences": [
    {
      "name": "packageManager",
      "title": "Global Package Manager",
      "description": "The package manager to use for global operations",
      "type": "dropdown",
      "data": [
        {
          "title": "npm",
          "value": "npm"
        },
        {
          "title": "bun",
          "value": "bun"
        },
        {
          "title": "pnpm",
          "value": "pnpm"
        }
      ],
      "default": "npm",
      "required": true
    }
  ],
  "scripts": {
    "build": "vici build",
    "dev": "vici develop",
    "format": "biome format --write src",
    "lint": "vici lint"
  },
  "dependencies": {
    "@raycast/utils": "^2.2.3",
    "@uidotdev/usehooks": "^2.4.1",
    "@vicinae/api": "^0.20.9",
    "find-up": "^8.0.0",
    "package-manager-detector": "^1.6.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/semver": "^7.7.1",
    "typescript": "^5.9.3"
  }
}
